# Copy to .env. Defaults are tuned for `docker compose up` to just work.

STORE_ID=ST1008
STORE_NAME=Brigade_Bangalore
TZ=Asia/Kolkata

# synthetic | video | rtsp
INGEST_MODE=synthetic
VIDEO_PATH=/data/video/sample.mp4
RTSP_URL=

# Business thresholds — see docs/CHOICES.md §4
ENGAGEMENT_DWELL_S=20
POS_JOIN_WINDOW_S=90
REENTRY_GAP_S=60

# Detection
YOLO_MODEL=yolov8n.pt
DET_CONF=0.4

LOG_LEVEL=INFO
